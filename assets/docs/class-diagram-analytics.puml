@startuml Analytics

skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam shadowing false

package "Analytics" {

    ' Value Objects
    class UserId <<Value Object>> <<Record>> {
        - userId: Long
    }

    class PropertyId <<Value Object>> <<Record>> {
        - propertyId: Long
    }

    class DeviceId <<Value Object>> <<Record>> {
        - deviceId: Long
    }

    class EnergyConsumption <<Value Object>> <<Record>> {
        - value: Double
        - unit: String
    }

    class ConsumptionPeriod <<Value Object>> <<Record>> {
        - startDate: Date
        - endDate: Date
    }

    enum MetricType <<Enum>> {
        ENERGY_CONSUMPTION
        USAGE_TIME
        USAGE_FREQUENCY
    }

    enum AlertSeverity <<Enum>> {
        LOW
        MEDIUM
        HIGH
    }

    ' Aggregates and Entities
    class ConsumptionMetric <<Aggregate Root>> {
        - id: Long
        - propertyId: PropertyId
        - deviceId: DeviceId
        - metricType: MetricType
        - value: EnergyConsumption
        - period: ConsumptionPeriod
        - calculatedAt: Date
        + ConsumptionMetric(command: CalculateMetricsCommand)
    }

    class ConsumptionReport <<Aggregate Root>> {
        - id: Long
        - userId: UserId
        - propertyId: PropertyId
        - period: ConsumptionPeriod
        - totalConsumption: EnergyConsumption
        - isAutomatic: Boolean
        - generatedAt: Date
        - items: List<ReportItem>
        + ConsumptionReport(command: GenerateConsumptionReportCommand)
        + addItem(deviceId: DeviceId, deviceName: String, consumption: EnergyConsumption, usageFrequency: Integer): ReportItem
    }

    class ReportItem <<Entity>> {
        - id: Long
        - deviceId: DeviceId
        - deviceName: String
        - consumption: EnergyConsumption
        - usageFrequency: Integer
    }

    class ConsumptionAlert <<Aggregate Root>> {
        - id: Long
        - userId: UserId
        - propertyId: PropertyId
        - deviceId: DeviceId
        - severity: AlertSeverity
        - message: String
        - threshold: Double
        - currentValue: Double
        - isRead: Boolean
        - triggeredAt: Date
        + ConsumptionAlert(command: TriggerConsumptionAlertCommand)
        + markAsRead(): ConsumptionAlert
    }

    ' Commands
    class CalculateMetricsCommand <<Command>> <<Record>> {
        - propertyId: Long
        - deviceId: Long
        - metricType: MetricType
        - value: Double
        - unit: String
    }

    class GenerateConsumptionReportCommand <<Command>> <<Record>> {
        - userId: Long
        - propertyId: Long
        - startDate: Date
        - endDate: Date
        - isAutomatic: Boolean
    }

    class TriggerConsumptionAlertCommand <<Command>> <<Record>> {
        - userId: Long
        - propertyId: Long
        - deviceId: Long
        - severity: AlertSeverity
        - threshold: Double
        - currentValue: Double
    }

    class MarkAlertAsReadCommand <<Command>> <<Record>> {
        - alertId: Long
    }

    ' Queries
    class GetMetricsByPropertyIdQuery <<Query>> <<Record>> {
        - propertyId: PropertyId
    }

    class GetDashboardSummaryByUserIdQuery <<Query>> <<Record>> {
        - userId: UserId
    }

    class GetReportsByPropertyIdQuery <<Query>> <<Record>> {
        - propertyId: PropertyId
    }

    class GetAlertsByUserIdQuery <<Query>> <<Record>> {
        - userId: UserId
    }

    ' Repositories (ports)
    interface ConsumptionMetricRepository <<Repository>> {
        + findById(id: Long): Optional<ConsumptionMetric>
        + findByPropertyId(propertyId: PropertyId): List<ConsumptionMetric>
        + save(metric: ConsumptionMetric): ConsumptionMetric
    }

    interface ConsumptionReportRepository <<Repository>> {
        + findById(id: Long): Optional<ConsumptionReport>
        + findByPropertyId(propertyId: PropertyId): List<ConsumptionReport>
        + save(report: ConsumptionReport): ConsumptionReport
    }

    interface ConsumptionAlertRepository <<Repository>> {
        + findById(id: Long): Optional<ConsumptionAlert>
        + findByUserIdAndIsReadFalse(userId: UserId): List<ConsumptionAlert>
        + save(alert: ConsumptionAlert): ConsumptionAlert
    }

    ' Application Services
    interface AnalyticsCommandService <<Service>> {
        + handle(command: CalculateMetricsCommand): Result<Long, ApplicationError>
        + handle(command: GenerateConsumptionReportCommand): Result<Long, ApplicationError>
        + handle(command: TriggerConsumptionAlertCommand): Result<Long, ApplicationError>
        + handle(command: MarkAlertAsReadCommand): Result<ConsumptionAlert, ApplicationError>
    }

    interface AnalyticsQueryService <<Service>> {
        + handle(query: GetMetricsByPropertyIdQuery): List<ConsumptionMetric>
        + handle(query: GetDashboardSummaryByUserIdQuery): List<ConsumptionMetric>
        + handle(query: GetReportsByPropertyIdQuery): List<ConsumptionReport>
        + handle(query: GetAlertsByUserIdQuery): List<ConsumptionAlert>
    }

    ' Event Handlers
    class UsageDataGeneratedEventHandler <<Event Handler>> {
        + on(event: UsageDataGeneratedEvent): void
    }

    ' Relations
    ConsumptionMetric *-- PropertyId : propertyId >
    ConsumptionMetric *-- DeviceId : deviceId >
    ConsumptionMetric *-- EnergyConsumption : value >
    ConsumptionMetric *-- ConsumptionPeriod : period >
    ConsumptionMetric --> MetricType : metricType >
    ConsumptionReport "1" *-- "0..*" ReportItem : contains >
    ConsumptionReport *-- UserId : userId >
    ConsumptionReport *-- PropertyId : propertyId >
    ConsumptionReport *-- ConsumptionPeriod : period >
    ConsumptionReport *-- EnergyConsumption : totalConsumption >
    ReportItem *-- DeviceId : deviceId >
    ReportItem *-- EnergyConsumption : consumption >
    ConsumptionAlert *-- UserId : userId >
    ConsumptionAlert *-- PropertyId : propertyId >
    ConsumptionAlert *-- DeviceId : deviceId >
    ConsumptionAlert --> AlertSeverity : severity >
    AnalyticsCommandService --> ConsumptionMetricRepository : uses >
    AnalyticsCommandService --> ConsumptionReportRepository : uses >
    AnalyticsCommandService --> ConsumptionAlertRepository : uses >
    AnalyticsQueryService --> ConsumptionMetricRepository : uses >
    AnalyticsQueryService --> ConsumptionReportRepository : uses >
    AnalyticsQueryService --> ConsumptionAlertRepository : uses >
    UsageDataGeneratedEventHandler --> AnalyticsCommandService : delegates to >
    ConsumptionMetricRepository ..> ConsumptionMetric : manages >
    ConsumptionReportRepository ..> ConsumptionReport : manages >
    ConsumptionAlertRepository ..> ConsumptionAlert : manages >
}

@enduml
