@startuml Subscriptions

skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam shadowing false

package "Subscriptions" {

    ' Value Objects
    class UserId <<Value Object>> <<Record>> {
        - userId: Long
    }

    class PlanId <<Value Object>> <<Record>> {
        - planId: Long
    }

    class SubscriptionId <<Value Object>> <<Record>> {
        - subscriptionId: Long
    }

    class Money <<Value Object>> <<Record>> {
        - amount: BigDecimal
        - currency: String
    }

    enum PlanType <<Enum>> {
        FREE
        PREMIUM
    }

    enum BillingCycle <<Enum>> {
        MONTHLY
        YEARLY
    }

    enum SubscriptionStatus <<Enum>> {
        ACTIVE
        CANCELLED
        EXPIRED
    }

    enum PaymentStatus <<Enum>> {
        PENDING
        COMPLETED
        FAILED
    }

    ' Aggregates
    class Plan <<Aggregate Root>> {
        - id: Long
        - name: String
        - type: PlanType
        - price: Money
        - billingCycle: BillingCycle
        - maxDevices: Integer
        - hasAdvancedMetrics: Boolean
        - hasCustomReports: Boolean
        - hasAlerts: Boolean
        - hasUnlimitedHistory: Boolean
        - isActive: Boolean
    }

    class Subscription <<Aggregate Root>> {
        - id: Long
        - userId: UserId
        - planId: PlanId
        - status: SubscriptionStatus
        - startDate: Date
        - endDate: Date
        - autoRenew: Boolean
        + Subscription(command: CreateSubscriptionCommand)
        + activate(): Subscription
        + cancel(): Subscription
        + renew(): Subscription
        + changePlan(planId: PlanId): Subscription
    }

    class Payment <<Aggregate Root>> {
        - id: Long
        - subscriptionId: SubscriptionId
        - amount: Money
        - status: PaymentStatus
        - externalPaymentId: String
        - processedAt: Date
        + Payment(command: ProcessPaymentCommand)
        + confirm(externalPaymentId: String): Payment
        + fail(): Payment
    }

    ' Commands
    class CreateSubscriptionCommand <<Command>> <<Record>> {
        - userId: Long
        - planId: Long
        - autoRenew: Boolean
    }

    class ChangeSubscriptionPlanCommand <<Command>> <<Record>> {
        - subscriptionId: Long
        - planId: Long
    }

    class CancelSubscriptionCommand <<Command>> <<Record>> {
        - subscriptionId: Long
    }

    class RenewSubscriptionCommand <<Command>> <<Record>> {
        - subscriptionId: Long
    }

    class ProcessPaymentCommand <<Command>> <<Record>> {
        - subscriptionId: Long
        - amount: BigDecimal
        - currency: String
    }

    ' Queries
    class GetAllPlansQuery <<Query>> <<Record>> {
    }

    class GetActiveSubscriptionByUserIdQuery <<Query>> <<Record>> {
        - userId: UserId
    }

    class GetPaymentsBySubscriptionIdQuery <<Query>> <<Record>> {
        - subscriptionId: SubscriptionId
    }

    ' Repositories (ports)
    interface PlanRepository <<Repository>> {
        + findById(id: Long): Optional<Plan>
        + findAllByIsActiveTrue(): List<Plan>
        + save(plan: Plan): Plan
    }

    interface SubscriptionRepository <<Repository>> {
        + findById(id: Long): Optional<Subscription>
        + findActiveByUserId(userId: UserId): Optional<Subscription>
        + save(subscription: Subscription): Subscription
    }

    interface PaymentRepository <<Repository>> {
        + findById(id: Long): Optional<Payment>
        + findBySubscriptionId(subscriptionId: SubscriptionId): List<Payment>
        + save(payment: Payment): Payment
    }

    ' Application Services
    interface SubscriptionCommandService <<Service>> {
        + handle(command: CreateSubscriptionCommand): Result<Long, ApplicationError>
        + handle(command: ChangeSubscriptionPlanCommand): Result<Subscription, ApplicationError>
        + handle(command: CancelSubscriptionCommand): Result<Subscription, ApplicationError>
        + handle(command: RenewSubscriptionCommand): Result<Subscription, ApplicationError>
        + handle(command: ProcessPaymentCommand): Result<Long, ApplicationError>
    }

    interface SubscriptionQueryService <<Service>> {
        + handle(query: GetAllPlansQuery): List<Plan>
        + handle(query: GetActiveSubscriptionByUserIdQuery): Optional<Subscription>
        + handle(query: GetPaymentsBySubscriptionIdQuery): List<Payment>
    }

    ' Outbound adapter to the external payment service
    class ExternalPaymentService <<Adapter>> {
        + processPayment(amount: Money, subscriptionId: Long): String
    }

    ' ACL Facade
    interface SubscriptionsContextFacade <<Facade>> {
        + fetchMaxDevicesForUser(userId: Long): Integer
        + hasFeature(userId: Long, feature: String): Boolean
    }

    ' Relations
    Plan *-- Money : price >
    Plan --> PlanType : type >
    Plan --> BillingCycle : billingCycle >
    Subscription *-- UserId : userId >
    Subscription *-- PlanId : planId >
    Subscription --> SubscriptionStatus : status >
    Payment *-- SubscriptionId : subscriptionId >
    Payment *-- Money : amount >
    Payment --> PaymentStatus : status >
    SubscriptionCommandService --> PlanRepository : uses >
    SubscriptionCommandService --> SubscriptionRepository : uses >
    SubscriptionCommandService --> PaymentRepository : uses >
    SubscriptionCommandService --> ExternalPaymentService : processes payments >
    SubscriptionQueryService --> PlanRepository : uses >
    SubscriptionQueryService --> SubscriptionRepository : uses >
    SubscriptionQueryService --> PaymentRepository : uses >
    PlanRepository ..> Plan : manages >
    SubscriptionRepository ..> Subscription : manages >
    PaymentRepository ..> Payment : manages >
    SubscriptionsContextFacade ..> SubscriptionQueryService : delegates to >
}

@enduml
