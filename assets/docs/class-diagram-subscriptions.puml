@startuml Subscriptions

skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam shadowing false

package "Subscriptions" {

    ' Value Objects
    class UserId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: UserId): Boolean
    }

    class SubscriptionId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: SubscriptionId): Boolean
    }

    class PlanId <<Value Object>> {
        - value: Long
        + getValue(): Long
        + equals(other: PlanId): Boolean
    }

    class Email <<Value Object>> {
        - value: String
        + getValue(): String
        + equals(other: Email): Boolean
    }

    class Money <<Value Object>> {
        - amount: Double
        - currency: String
        + getAmount(): Double
        + getCurrency(): String
        + equals(other: Money): Boolean
    }

    class PlanFeatures <<Value Object>> {
        - maxDevices: Integer
        - hasAdvancedMetrics: Boolean
        - hasCustomReports: Boolean
        - hasAlerts: Boolean
        - hasUnlimitedHistory: Boolean
        + getMaxDevices(): Integer
        + hasAdvancedMetrics(): Boolean
        + hasCustomReports(): Boolean
        + hasAlerts(): Boolean
        + hasUnlimitedHistory(): Boolean
        + equals(other: PlanFeatures): Boolean
    }

    ' Enumerations
    enum PlanType <<Enum>> {
        FREE
        BASIC
        PREMIUM
    }

    enum SubscriptionStatus <<Enum>> {
        ACTIVE
        CANCELLED
        EXPIRED
        PENDING
    }

    enum PaymentStatus <<Enum>> {
        PENDING
        COMPLETED
        FAILED
        REFUNDED
    }

    enum BillingCycle <<Enum>> {
        MONTHLY
        ANNUAL
    }

    ' Entities
    class Plan <<Entity>> {
        - id: PlanId
        - name: String
        - planType: PlanType
        - price: Money
        - billingCycle: BillingCycle
        - features: PlanFeatures
        - isActive: Boolean
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        + getId(): PlanId
        + getName(): String
        + getPlanType(): PlanType
        + getPrice(): Money
        + getBillingCycle(): BillingCycle
        + getFeatures(): PlanFeatures
        + isActive(): Boolean
    }

    class Subscription <<Aggregate Root>> <<Entity>> {
        - id: SubscriptionId
        - userId: UserId
        - planId: PlanId
        - status: SubscriptionStatus
        - startDate: LocalDate
        - endDate: LocalDate
        - autoRenew: Boolean
        - createdAt: LocalDateTime
        - updatedAt: LocalDateTime
        + getId(): SubscriptionId
        + getUserId(): UserId
        + getPlanId(): PlanId
        + getStatus(): SubscriptionStatus
        + getStartDate(): LocalDate
        + getEndDate(): LocalDate
        + isAutoRenew(): Boolean
        + activate(): void
        + cancel(): void
        + expire(): void
        + isActive(): Boolean
    }

    class Payment <<Entity>> {
        - id: Long
        - subscriptionId: SubscriptionId
        - amount: Money
        - status: PaymentStatus
        - externalPaymentId: String
        - processedAt: LocalDateTime
        + getId(): Long
        + getSubscriptionId(): SubscriptionId
        + getAmount(): Money
        + getStatus(): PaymentStatus
        + getExternalPaymentId(): String
        + getProcessedAt(): LocalDateTime
        + markAsCompleted(externalId: String): void
        + markAsFailed(): void
    }

    ' Repositories
    interface SubscriptionRepository <<Repository>> {
        + findById(id: SubscriptionId): Optional<Subscription>
        + findByUserId(userId: UserId): Optional<Subscription>
        + findActiveByUserId(userId: UserId): Optional<Subscription>
        + save(subscription: Subscription): Subscription
        + deleteById(id: SubscriptionId): void
    }

    interface PlanRepository <<Repository>> {
        + findById(id: PlanId): Optional<Plan>
        + findByPlanType(planType: PlanType): Optional<Plan>
        + findAllActive(): List<Plan>
        + save(plan: Plan): Plan
    }

    interface PaymentRepository <<Repository>> {
        + findById(id: Long): Optional<Payment>
        + findBySubscriptionId(subscriptionId: SubscriptionId): List<Payment>
        + save(payment: Payment): Payment
    }

    ' Services
    class SubscriptionService <<Service>> {
        - subscriptionRepository: SubscriptionRepository
        - planRepository: PlanRepository
        - paymentComponent: PaymentComponent
        + createSubscription(userId: UserId, planId: PlanId, billingCycle: BillingCycle): Subscription
        + cancelSubscription(subscriptionId: SubscriptionId): Subscription
        + upgradeSubscription(subscriptionId: SubscriptionId, newPlanId: PlanId): Subscription
        + getSubscriptionByUserId(userId: UserId): Subscription
        + getAvailablePlans(): List<Plan>
        + renewSubscription(subscriptionId: SubscriptionId): Subscription
    }

    class PaymentComponent <<Service>> {
        - paymentRepository: PaymentRepository
        + processPayment(subscription: Subscription, amount: Money): Payment
        + refundPayment(paymentId: Long): Payment
        + getPaymentsBySubscriptionId(subscriptionId: SubscriptionId): List<Payment>
    }

    ' Relations
    Subscription "1" *-- "0..*" Payment : records >
    Subscription --> Plan : subscribes to >
    Subscription --> SubscriptionStatus : uses >
    Subscription *-- SubscriptionId : id >
    Subscription *-- UserId : userId >
    Subscription *-- PlanId : planId >
    Plan --> PlanType : uses >
    Plan --> BillingCycle : uses >
    Plan *-- PlanFeatures : features >
    Plan *-- Money : price >
    Plan *-- PlanId : id >
    Payment --> PaymentStatus : uses >
    Payment *-- Money : amount >
    Payment *-- SubscriptionId : subscriptionId >
    SubscriptionService --> SubscriptionRepository : uses >
    SubscriptionService --> PlanRepository : uses >
    SubscriptionService --> PaymentComponent : uses >
    PaymentComponent --> PaymentRepository : uses >
    SubscriptionRepository ..> Subscription : manages >
    PlanRepository ..> Plan : manages >
    PaymentRepository ..> Payment : manages >
}

@enduml